{
  "name": "atlassian-migration-advisor",
  "version": "0.1.0",
  "description": "Cloudflare Workers-based Atlassian Data Center pre-migration analysis tool",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit && esbuild index.ts --bundle --outdir=dist --format=esm --platform=browser",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts' && prettier --check 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix && prettier --write 'src/**/*.ts'",
    "type-check": "tsc --noEmit",
    "validate-config": "node scripts/validate-config.mjs",
    "generate-report": "node scripts/trigger-report.mjs"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250224.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "miniflare": "^3.20250224.0",
    "prettier": "^3.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.100.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
